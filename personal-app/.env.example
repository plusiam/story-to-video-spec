# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# App Config
VITE_AUTO_APPROVE_USERS=true  # MVP: true, Production: false
VITE_ENABLE_AI_FEATURES=false  # AI 기능 활성화 여부
VITE_ADMIN_EMAILS=admin@example.com  # 쉼표로 구분하여 여러 이메일 지정 가능
VITE_JUDGE_EMAILS=judge@example.com  # 심사위원 이메일 (쉼표로 구분 가능)

# AI (Optional - for future)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key
