{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Story Creator v2 Export Schema",
  "description": "AI 도구와 연동 가능한 스토리 데이터 스키마",
  "version": "2.0",
  "type": "object",
  "required": ["version", "metadata", "story"],
  "properties": {
    "version": {
      "type": "string",
      "description": "스키마 버전",
      "const": "2.0"
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time",
      "description": "내보내기 시간 (ISO 8601)"
    },
    "metadata": {
      "type": "object",
      "description": "스토리 메타데이터",
      "required": ["title", "structure"],
      "properties": {
        "title": {
          "type": "string",
          "description": "스토리 제목",
          "maxLength": 100
        },
        "theme": {
          "type": "string",
          "description": "핵심 주제/메시지 (예: 용기, 우정, 환경보호)"
        },
        "genre": {
          "type": "string",
          "description": "장르",
          "enum": ["fantasy", "adventure", "slice-of-life", "comedy", "mystery", "educational", "other"]
        },
        "targetAge": {
          "type": "string",
          "description": "대상 연령대",
          "enum": ["3-5", "6-8", "9-12", "13+", "all"]
        },
        "structure": {
          "type": "string",
          "description": "스토리 구조 유형",
          "enum": ["kisungjeongyul", "three-act", "hero-journey", "custom"]
        },
        "structureName": {
          "type": "string",
          "description": "구조 이름 (표시용)",
          "examples": ["기승전결", "3막 구조", "영웅의 여정"]
        },
        "outputFormats": {
          "type": "array",
          "description": "의도된 출력 형식",
          "items": {
            "type": "string",
            "enum": ["picturebook", "animation", "youtube", "webtoon", "other"]
          }
        },
        "language": {
          "type": "string",
          "description": "언어 코드",
          "default": "ko"
        },
        "author": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "school": { "type": "string" },
            "class": { "type": "string" }
          }
        }
      }
    },
    "setting": {
      "type": "object",
      "description": "배경 설정",
      "properties": {
        "place": {
          "type": "string",
          "description": "장소 (예: 마법의 숲, 작은 마을)"
        },
        "time": {
          "type": "string",
          "description": "시간/시대 (예: 현대, 옛날 옛적에)"
        },
        "atmosphere": {
          "type": "string",
          "description": "분위기 (예: 따뜻한, 신비로운, 긴장감 있는)"
        },
        "visualStyle": {
          "type": "string",
          "description": "시각적 스타일 (예: 수채화, 파스텔, 애니메이션)"
        }
      }
    },
    "characters": {
      "type": "array",
      "description": "등장인물 목록",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "캐릭터 고유 ID"
          },
          "name": {
            "type": "string",
            "description": "캐릭터 이름"
          },
          "role": {
            "type": "string",
            "description": "역할",
            "enum": ["protagonist", "antagonist", "supporting", "mentor", "other"]
          },
          "description": {
            "type": "string",
            "description": "성격, 외모, 특징"
          },
          "visualDescription": {
            "type": "string",
            "description": "AI 이미지 생성용 시각적 묘사"
          },
          "emoji": {
            "type": "string",
            "description": "대표 이모지"
          }
        }
      }
    },
    "story": {
      "type": "object",
      "description": "스토리 본문",
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "array",
          "description": "스토리 단계 (기승전결/3막 등)",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": {
                "type": "string",
                "description": "단계 ID (예: 기, 승, 전, 결)"
              },
              "name": {
                "type": "string",
                "description": "단계 이름"
              },
              "title": {
                "type": "string",
                "description": "단계 제목"
              },
              "summary": {
                "type": "string",
                "description": "이 단계의 줄거리 요약"
              },
              "scenes": {
                "type": "array",
                "description": "세부 장면 목록",
                "items": {
                  "type": "object",
                  "properties": {
                    "sceneNumber": {
                      "type": "integer",
                      "description": "장면 번호"
                    },
                    "content": {
                      "type": "string",
                      "description": "장면 내용/나레이션"
                    },
                    "dialogue": {
                      "type": "array",
                      "description": "대사 목록",
                      "items": {
                        "type": "object",
                        "properties": {
                          "character": { "type": "string" },
                          "text": { "type": "string" },
                          "emotion": { "type": "string" }
                        }
                      }
                    },
                    "imagePrompt": {
                      "type": "string",
                      "description": "AI 이미지 생성용 프롬프트"
                    },
                    "cameraAngle": {
                      "type": "string",
                      "description": "카메라 앵글 (영상용)",
                      "enum": ["wide", "medium", "close-up", "bird-eye", "low-angle", "other"]
                    },
                    "duration": {
                      "type": "number",
                      "description": "예상 장면 길이 (초)"
                    },
                    "soundEffect": {
                      "type": "string",
                      "description": "효과음 설명"
                    },
                    "music": {
                      "type": "string",
                      "description": "배경 음악 분위기"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "aiPrompts": {
      "type": "object",
      "description": "AI 도구 연동용 프롬프트",
      "properties": {
        "imageGeneration": {
          "type": "array",
          "description": "이미지 생성 프롬프트 목록",
          "items": {
            "type": "object",
            "properties": {
              "stage": { "type": "string" },
              "sceneNumber": { "type": "integer" },
              "prompt": { "type": "string" },
              "negativePrompt": { "type": "string" },
              "style": { "type": "string" }
            }
          }
        },
        "storyExpansion": {
          "type": "string",
          "description": "스토리 확장용 AI 프롬프트"
        },
        "voiceNarration": {
          "type": "string",
          "description": "TTS 나레이션용 스크립트"
        }
      }
    },
    "exportSettings": {
      "type": "object",
      "description": "내보내기 설정",
      "properties": {
        "imageStyle": {
          "type": "string",
          "description": "이미지 스타일 프리셋",
          "enum": ["watercolor", "pastel", "anime", "cartoon", "realistic", "minimalist"]
        },
        "aspectRatio": {
          "type": "string",
          "description": "이미지 비율",
          "enum": ["1:1", "4:3", "16:9", "9:16", "3:4"]
        },
        "pageCount": {
          "type": "integer",
          "description": "목표 페이지 수 (그림책용)"
        }
      }
    }
  }
}
